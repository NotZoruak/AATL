{
    "name": "AATL",
    "version": "0.1.0",
    "icon": "AATL.ico",
    "custom_title": "AATL - 刀剑乱舞自动化助手",

    "controller": [
        {
            "name": "mumu",
            "label": "MuMu 模拟器",
            "description": "docs/mumu.md",
            "type": "Adb",
            "display_short_side": 720,
            "adb": {
                "adb_path": "{ADB}",
                "address": "127.0.0.1:7555",
                "screencap_method": 0,
                "input_method": 0
            }
        }
    ],

    "resource": [
        {
            "name": "刀剑乱舞",
            "path": ["{PROJECT_DIR}/resource/base"],
            "DisplayName": "刀剑乱舞",
            "DisplayDescription": "刀剑乱舞（Touken Ranbu）自动化资源"
        }
    ],

    "task": [
        {
            "name": "远征",
            "entry": "Expedition",
            "default_check": true,
            "repeatable": false,
            "repeat_count": 0,
            "option": [
                "部队一",
                "部队二",
                "部队三",
                "部队四",
                "部队五",
                "RefreshInterval"
            ],
            "DisplayName": "远征",
            "DisplayDescription": "自动收发远征队伍"
        },
        {
            "name": "合战场",
            "entry": "Battlefield",
            "default_check": false,
            "repeatable": true,
            "repeat_count": 1,
            "DisplayName": "合战场",
            "DisplayDescription": "自动出阵合战场"
